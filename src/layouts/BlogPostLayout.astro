---
import Header from "../components/Header.astro";
import Divider from "../components/Divider.astro";
import Footer from "../components/Footer.astro";

import "../styles/globals.css";
import BaseHead from "../components/BaseHead.astro";

interface Props {
  id: string;
  title: string;
  author: string;
  description: string;
  tags: string[];
  published: string | Date;
  ogImage?: string;
}

const { id, title, description, published, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />

    <!-- Title / Description -->
    <title>{title}</title>
    <meta property="description" content={description} />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://www.nickcosmo.com/blog/${id}`} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={`https://www.nickcosmo.com/${ogImage || "og-image.png"}`}
    />
    <meta property="og:image:alt" content="" />
  </head>
  <body>
    <Header />
    <Divider />
    <div class="container fadeIn" transition:animate="none">
      <div class="title-container">
        <h1>{title}</h1>
        <p class="post-timestamp">
          <time>{new Date(published).toLocaleDateString()}</time>
        </p>
      </div>
      <div class="blog-content">
        <slot />
      </div>
    </div>
    <Footer />
  </body>
</html>

<style is:global></style>
