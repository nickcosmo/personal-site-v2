---
import Header from "../components/Header.astro";
import Divider from "../components/Divider.astro";
import Footer from "../components/Footer.astro";
import BaseHead from "../components/BaseHead.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />

    <!-- Title / Description -->
    <title>Nick Cosmo</title>
    <meta
      property="description"
      content="I’m a software engineer and web developer based in Portland,
        OR. I specialize in the JavaScript and TypeScript ecosystem and I’m
        passionate about building products and features that solve hard problems
        and enhance user experiences."
    />

    <!-- OG Tags -->
    <meta property="og:title" content="Nick Cosmo" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.nickcosmo.com/" />
    <meta
      property="og:description"
      content="I’m a software engineer and web developer based in Portland,
        OR. I specialize in the JavaScript and TypeScript ecosystem and I’m
        passionate about building products and features that solve hard problems
        and enhance user experiences."
    />
    <meta
      property="og:image"
      content="https://www.nickcosmo.com/og-image.png"
    />
    <meta property="og:image:alt" content="" />
  </head>
  <body>
    <Header />
    <Divider />
    <main class="fadeIn" transition:animate="none">
      <slot />
    </main>
    <Footer />
  </body>
</html>
