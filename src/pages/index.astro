---
import Divider from "../components/Divider.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";
import "../styles/index.css";

import { getCollection } from "astro:content";

const blog = await getCollection("blog");

const allPosts = blog
  .filter((post) => !!post.data.published)
  .sort(
    (a, b) =>
      (b.data.published || 0).valueOf() - (a.data.published || 0).valueOf(),
  );
---

<Layout>
  <div class="hero-wrapper container">
    <div class="hero-image-container bordered">
      <img src="/headshot.jpg" alt="Me" />
    </div>
    <div style="flex: 1.25">
      <h1>Hello! I'm Nick.</h1>
      <p>Full stack software engineer and tinkerer.</p>
    </div>
  </div>
  <div class="container">
    <h2>About</h2>
    <Divider />
    <p>
      I'm a software engineer and web developer based in Portland, OR and I
      specialize in the JavaScript and TypeScript ecosystem.
    </p>
    <p>
      I see programming as a creative craft, where problem solving meets
      creative thinking. Whether I’m architecting APIs or tweaking UI
      interactions, I enjoy the process of building apps and writing code.
    </p>
    <p>
      Outside of coding, you can find me skateboarding, making/eating pizza,
      playing soccer, reading sci-fi, or watching a movie.
    </p>
  </div>
  <div class="container">
    <h2>Blog Posts</h2>
    <Divider />

    <ul>
      {
        allPosts.map((post) => (
          <li class="post">
            <a href={`/blog/${post.id.split("/").pop() || ""}`}>
              {post.data.title}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
  <!-- <div class="container">
   WIP
    <h2>Tech I Love</h2>
    <Divider />

    <ul>
      <li>TypeScript</li>
      <li>React</li>
      <li>Node.js</li>
      <li>GraphQL</li>
      <li>Astro</li>
      <li>Google Cloud</li>
      <li>Vite</li>
    </ul>
  </div> -->
  <div class="container">
    <h2>Contact</h2>
    <Divider />

    <p>
      I'm always open to connecting with other developers, collaborating on
      projects, or just chatting about tech and programming. Feel free to reach
      out to me on{" "}
      <a href="https://www.linkedin.com/in/nicholasclansing/" target="_blank">
        LinkedIn
      </a>{" "}
      or check out my{" "}
      <a href="https://github.com/nickcosmo" target="_blank">GitHub</a>.
    </p>
  </div>
</Layout>

<style>
  ul {
    padding-left: 20px;
  }

  .post a {
    width: 100%;
    display: block;
    height: 100%;
    color: var(--secondary-color);
  }

  .post:hover {
    color: var(--accent-color);

    > a {
      text-decoration: underline;
      color: var(--accent-color);
    }
  }
</style>
